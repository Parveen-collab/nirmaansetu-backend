{
  "openapi": "3.0.1",
  "info": {
    "title": "NirmaanSetu API",
    "description": "Complete Backend API for NirmaanSetu Platform",
    "version": "v1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {

    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth APIs"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequestDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponseDto" }
              }
            }
          }
        }
      }
    },

    "/api/v1/auth/send-otp": {
      "post": {
        "tags": ["Auth APIs"],
        "summary": "Send OTP",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OtpRequestDto" }
            }
          }
        },
        "responses": { "200": { "description": "OTP sent" } }
      }
    },

    "/api/v1/auth/verify-otp": {
      "post": {
        "tags": ["Auth APIs"],
        "summary": "Verify OTP",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VerifyOtpRequestDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponseDto" }
              }
            }
          }
        }
      }
    },

    "/api/v1/auth/send-otp-forgot": {
      "post": {
        "tags": ["Auth APIs"],
        "summary": "Send OTP for password reset",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OtpRequestDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP sent" },
          "404": { "description": "User not found" }
        }
      }
    },

    "/api/v1/auth/reset-password": {
      "post": {
        "tags": ["Auth APIs"],
        "summary": "Reset password",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResetPasswordRequestDto" }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset successful" }
        }
      }
    },

    "/api/v1/auth/refresh": {
      "post": {
        "tags": ["Auth APIs"],
        "summary": "Refresh token",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "refreshToken",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponseDto" }
              }
            }
          }
        }
      }
    },

    "/api/v1/user/register": {
      "post": {
        "tags": ["User APIs"],
        "summary": "Register user",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "user": { "$ref": "#/components/schemas/UserRequestDto" },
                  "photo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponseDto" }
              }
            }
          }
        }
      }
    },

    "/api/v1/user/all": {
      "get": {
        "tags": ["User APIs"],
        "summary": "Get all users",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "role", "in": "query", "schema": { "$ref": "#/components/schemas/Role" } },
          { "name": "keyword", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/UserResponseDto" }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/user/{id}": {
      "get": {
        "tags": ["User APIs"],
        "summary": "Get user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponseDto" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["User APIs"],
        "summary": "Update user",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "user": { "$ref": "#/components/schemas/UserRequestDto" },
                  "photo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["User APIs"],
        "summary": "Delete user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "Deleted" }
        }
      }
    },

    "/api/v1/employees": {
      "get": {
        "tags": ["Employee APIs"],
        "summary": "Get all employees",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EmployeeResponseDto" }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/employers": {
      "get": {
        "tags": ["Employer APIs"],
        "summary": "Get all employers",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EmployerResponseDto" }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/employers/{id}": {
      "get": {
        "tags": ["Employer APIs"],
        "summary": "Get employer by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmployerResponseDto" }
              }
            }
          }
        }
      }
    },

    "/api/v1/enquiries": {
      "post": {
        "tags": ["Enquiry APIs"],
        "summary": "Send enquiry",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EnquiryRequestDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EnquiryResponseDto" }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Enquiry APIs"],
        "summary": "Get enquiries",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EnquiryResponseDto" }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/notifications": {
      "get": {
        "tags": ["Notification APIs"],
        "summary": "Get notifications",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/NotificationResponseDto" }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/orders": {
      "get": {
        "tags": ["Order APIs"],
        "summary": "Get all orders",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/OrderResponseDto" }
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/orders/{id}": {
      "get": {
        "tags": ["Order APIs"],
        "summary": "Get order by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrderResponseDto" }
              }
            }
          }
        }
      }
    },

    "/api/v1/payments": {
      "post": {
        "tags": ["Payment APIs"],
        "summary": "Process payment",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PaymentDto" }
            }
          }
        },
        "responses": { "200": { "description": "Success" } }
      },
      "get": {
        "tags": ["Payment APIs"],
        "summary": "Get payments",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      }
    },

    "/api/v1/projects": {
      "get": {
        "tags": ["Project APIs"],
        "summary": "Get projects",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Project APIs"],
        "summary": "Create project",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/api/v1/shops": {
      "get": {
        "tags": ["Shop APIs"],
        "summary": "Get shops",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Shop APIs"],
        "summary": "Create shop",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/api/v1/shops/{shopId}/materials": {
      "post": {
        "tags": ["Shop APIs"],
        "summary": "Add material",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Added" } }
      }
    }

  },

  "components": {
    "schemas": {
      "LoginRequestDto": { "type": "object" },
      "ResetPasswordRequestDto": { "type": "object" },
      "OtpRequestDto": { "type": "object" },
      "VerifyOtpRequestDto": { "type": "object" },
      "AuthResponseDto": { "type": "object" },
      "UserRequestDto": { "type": "object" },
      "UserResponseDto": { "type": "object" },
      "EmployeeResponseDto": { "type": "object" },
      "EmployerResponseDto": { "type": "object" },
      "EnquiryRequestDto": { "type": "object" },
      "EnquiryResponseDto": { "type": "object" },
      "NotificationResponseDto": { "type": "object" },
      "OrderResponseDto": { "type": "object" },
      "PaymentDto": { "type": "object" },
      "ProjectRequestDto": { "type": "object" },
      "ProjectResponseDto": { "type": "object" },
      "ShopRequestDto": { "type": "object" },
      "ShopResponseDto": { "type": "object" },
      "MaterialRequestDto": { "type": "object" },
      "MaterialResponseDto": { "type": "object" },
      "Role": {
        "type": "string",
        "enum": ["EMPLOYEE", "EMPLOYER", "SUPPLIER", "ADMIN", "SUPER_ADMIN"]
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}